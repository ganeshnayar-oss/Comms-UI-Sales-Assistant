# Runtime environment selection is configured in config/siebel.config.json
SIEBEL_CONFIG_PATH=./config/siebel.config.json
CUSTOMER_CONFIG_PATH=./config/customer.config.json

# One auth mode is typically enough. Prefer a session cookie if you already have an authenticated browser session.
SIEBEL_SESSION_COOKIE=
SIEBEL_BEARER_TOKEN=
SIEBEL_BASIC_USERNAME=
SIEBEL_BASIC_PASSWORD=

# Optional: LLM-backed intake parsing for the first page
# Supported providers:
# - INTAKE_LLM_PROVIDER=openai
# - INTAKE_LLM_PROVIDER=oci
# - INTAKE_LLM_PROVIDER=custom
# - INTAKE_LLM_PROVIDER=disabled
INTAKE_LLM_PROVIDER=disabled
INTAKE_LLM_API_KEY=
INTAKE_LLM_MODEL=gpt-5.4-mini
INTAKE_LLM_BASE_URL=
INTAKE_LLM_PROJECT=
INTAKE_LLM_OCI_REGION=

# Backward-compatible OpenAI settings are still supported
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
